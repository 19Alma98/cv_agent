# Copy to .env for local development (never commit .env).

# Required: Qdrant REST API base URL
QDRANT_URL=http://localhost:6333

# Optional: leave empty for local Docker Qdrant without auth
QDRANT_API_KEY=

# Phase 1+ — embeddings
# OpenAI (default): leave EMBEDDING_PROVIDER=openai or omit it
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
# Optional; default https://api.openai.com/v1
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
# Vector size for your model (e.g. 1536 for text-embedding-3-small)
# EMBEDDING_VECTOR_SIZE=1536

# Classic Azure OpenAI resource (*.openai.azure.com) + API key:
# EMBEDDING_PROVIDER=azure_openai
# EMBEDDING_BASE_URL=https://YOUR_RESOURCE_NAME.openai.azure.com
# EMBEDDING_MODEL=your-embedding-deployment-name
# EMBEDDING_API_KEY=<key>
# EMBEDDING_API_VERSION=2024-02-01

# Azure AI Foundry *project* (Entra ID / DefaultAzureCredential, OpenAI SDK …/openai/v1):
# EMBEDDING_PROVIDER=azure_foundry
# AZURE_AI_PROJECT_ENDPOINT=<project URL from Foundry, same idea as AZURE_PROJECT_ENDPOINT>
# EMBEDDING_MODEL=<embedding deployment name in the project>
# EMBEDDING_API_KEY=   (not used — authenticate with az login / managed identity / env vars)

# Phase 3 — agent / chat LLM
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
# LLM_PROVIDER=azure_openai
# LLM_BASE_URL=https://YOUR_RESOURCE_NAME.openai.azure.com
# LLM_MODEL=your-chat-deployment-name
# LLM_API_VERSION=2024-02-01

# Foundry project + Entra for chat (use openai_client_from_settings(..., for_llm=True) in code):
# LLM_PROVIDER=azure_foundry
# AZURE_AI_PROJECT_ENDPOINT=<same as embeddings if same project>
# LLM_MODEL=<chat deployment name>

# Phase 3 — POST /discover (optional overrides)
# DISCOVER_W_COVERAGE=0.5
# DISCOVER_W_VECTOR=0.5
# DISCOVER_MAX_CV_TEXT_CHARS=120000
# DISCOVER_RETRIEVAL_LIMIT_CVS=40
# DISCOVER_RETRIEVAL_LIMIT_CHUNKS=120
# DISCOVER_MAX_CVS_TO_SCORE=25
# DISCOVER_LLM_TIMEOUT_S=120
# DISCOVER_LLM_CONCURRENCY=4

# Optional — HTTP server (see cv_agent.__main__)
# CV_AGENT_HOST=127.0.0.1
# CV_AGENT_PORT=8000
# CV_AGENT_RELOAD=true
