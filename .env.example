# Copy to .env for local development (never commit .env).

# Required: Qdrant REST API base URL
QDRANT_URL=http://localhost:6333

# Optional: leave empty for local Docker Qdrant without auth
QDRANT_API_KEY=

# Phase 1+ — embeddings (example names; align with your provider)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# Phase 3 — agent / chat LLM
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Optional — HTTP server (see cv_agent.__main__)
# CV_AGENT_HOST=127.0.0.1
# CV_AGENT_PORT=8000
# CV_AGENT_RELOAD=true
